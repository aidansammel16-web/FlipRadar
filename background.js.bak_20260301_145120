function addOrReplaceQueryParam(url, key, value) {
  var base = url.split('#')[0];
  var hash = url.indexOf('#') !== -1 ? '#' + url.split('#')[1] : '';
  var parts = base.split('?');
  var path = parts[0];
  var params = parts[1] ? parts[1].split('&').filter(Boolean) : [];
  var found = false;
  for (var i = 0; i < params.length; i++) {
    if (params[i].split('=')[0] === key) {
      params[i] = key + '=' + value;
      found = true;
    }
  }
  if (!found) {
    params.push(key + '=' + value);
  }
  return path + '?' + params.join('&') + hash;
}


