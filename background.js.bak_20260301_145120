function hashCode(s) {
  var h = 0;
  for (var i = 0; i < s.length; i++) {
    h = ((h << 5) - h) + s.charCodeAt(i);
    h |= 0;
  }
  return Math.abs(h);
}

function scoreListing(listing, search) {
  var pts = 0;
  var price = Number(listing.price);
  var max = Number(search.maxPrice);
  if (max > 0 && price > 0) {
    if (price <= max * 0.50) pts += 3;
    else if (price <= max * 0.75) pts += 2;
    else if (price <= max) pts += 1;
  }
  var titleLower = (listing.title || '').toLowerCase();
  if (BRANDS.some(function (b) { return titleLower.includes(b); })) pts += 2;
  if (CONDITION_WORDS.some(function (c) { return titleLower.includes(c); })) pts += 1;
  // Electronics signals boost
  if (ELECTRONICS_SIGNALS.some(function (sig) { return titleLower.includes(sig); })) pts += 1;
  // Negative signals reduce score
  if (NEGATIVE_SIGNALS.some(function (neg) { return titleLower.includes(neg); })) pts -= 3;
  return pts;
}

